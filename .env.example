# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me

# LLM Provider
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini

# Groq
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama3-70b-8192

# Gemini
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-1.5-flash

# Redis
# Local development: redis://localhost:6379/0
# Production (Upstash): rediss://default:password@host:port
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Agents
AGENT_MAX_RETRIES=3
AGENT_RETRY_BASE_DELAY=1
AGENT_TIMEOUT=60

# Batching
MAX_BATCH_SIZE=10
BATCH_FLUSH_INTERVAL=5

# CORS
# Local development: http://localhost:3000,http://localhost:8000
# Production: https://your-frontend.vercel.app,https://your-backend.render.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000